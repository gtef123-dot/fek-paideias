# Cloudflare Worker configuration (example).
# For LOCAL dev: copy to ".dev.vars" (wrangler dev reads it). The GEMINI_API_KEY
# is a SECRET in production — set it with `npx wrangler secret put GEMINI_API_KEY`,
# never commit it.

# production | development
# - production: ALLOWED_ORIGINS is REQUIRED (else POST → 500 SERVER_CONFIG_ERROR)
# - development: also allows http://localhost:3000 and http://127.0.0.1:3000
ENVIRONMENT=development

# Comma-separated site origins allowed to call the Worker (your GitHub Pages URL).
# e.g. https://<user>.github.io
ALLOWED_ORIGINS=

# Per-IP requests/minute (best-effort abuse guard).
MAX_REQUESTS_PER_MINUTE=12

# Secret — local dev only (in .dev.vars). In production use `wrangler secret put`.
GEMINI_API_KEY=
